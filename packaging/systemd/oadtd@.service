[Unit]
Description=Open Agentic Threat Defense instance %i
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=oadtd
Group=oadtd
EnvironmentFile=-/etc/oadtd/%i.env
Environment=OATD_ADDR=127.0.0.1:8080
Environment=OATD_POLICY_PATH=/etc/oadtd/policy.json
WorkingDirectory=/opt/oadtd/current
ExecStart=/opt/oadtd/current/oadtd --addr ${OATD_ADDR} --instance-name %i --public-url ${OATD_PUBLIC_URL} --policy ${OATD_POLICY_PATH}
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
